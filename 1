// ====================== КЛАВИАТУРЫ ======================
function createKeyboard(row, prefix = 'Кнопка Ответа', linkPrefix = 'Цвет/Ссылка Ответа', maxButtons = 10) {
    try {
        // 🔥 НОВОЕ: Проверка типа клавиатуры из колонки "Кнопки в sms"
        const inlineSetting = (row['Кнопки в sms'] || 'ДА').trim().toUpperCase();
        const isInline = (inlineSetting === 'ДА');
        
        const buttons = [];
        
        for (let i = 1; i <= maxButtons; i++) {
            const btnText = (row[`${prefix}-${i}`] || '').trim();
            const btnLinkOrColor = (row[`${linkPrefix}-${i}`] || '').trim();
            
            if (!btnText) continue;
            
            let button = null;
            
            // 🔥 Разделяем цвет и ссылку (формат: "цвет||ссылка" или просто "цвет")
            const parts = (btnLinkOrColor || '').split('||');
            const colorValue = parts[0] || '';
            const linkValue = parts[1] || '';
            
            // 🔥 Нормализация: убираем пробелы, заменяем "ё" на "е", приводим к нижнему регистру
            const normalizedColor = colorValue.toLowerCase().replace(/ё/ig, 'е').trim();
            
            // 🔥 Проверяем, это ссылка или цвет
            if (normalizedColor === 'ссылка...' || linkValue.trim().startsWith('http')) {
                // 🔗 Кнопка-ссылка
                button = {
                    action: {
                        type: 'open_link',
                        link: linkValue.trim() || colorValue.trim(),
                        label: btnText.trim()
                    }
                };
                log('debug', `🔗 Link button: "${btnText}" → ${linkValue || colorValue}`);
                
            } else {
                // 🔘 Цветная кнопка
                let color = 'secondary';
                
                // 🔥 Поддержка всех форм слов + нормализация "ё" → "е"
                // Красный: красный, красная, красное, красные, красн, negative, red
                if (/^красн/.test(normalizedColor) || normalizedColor === 'negative' || normalizedColor === 'red') {
                    color = 'negative';
                }
                // Зелёный: зеленый, зелёный, зеленая, зелёная, зеленое, зелёное, зеленые, зелёные, зелен, зелё, позитив, positive, green
                else if (/^зелен/.test(normalizedColor) || /^зелён/.test(normalizedColor) || normalizedColor === 'positive' || normalizedColor === 'green') {
                    color = 'positive';
                }
                // Синий: синий, синяя, синее, синие, син, первичный, primary, blue
                else if (/^син/.test(normalizedColor) || normalizedColor === 'primary' || normalizedColor === 'blue') {
                    color = 'primary';
                }
                // Белый: белый, белая, белое, белые, бел, белый, white
                else if (/^бел/.test(normalizedColor) || normalizedColor === 'white') {
                    color = 'secondary';
                }
                // Серый: серый, серая, серое, серые, сер, серый, серый, gray, grey
                else if (/^сер/.test(normalizedColor) || normalizedColor === 'gray' || normalizedColor === 'grey') {
                    color = 'secondary';
                }
                
                button = {
                    action: {
                        type: 'text',
                        label: btnText.trim(),
                        payload: JSON.stringify({ button: i })
                    },
                    color: color
                };
                
                log('debug', `🔘 Button "${btnText}" color: "${normalizedColor}" → VK color: "${color}"`);
            }
            
            if (button) {
                buttons.push([button]);
            }
        }
        
        if (buttons.length > 0) {
            const keyboard = {
                one_time: false,
                inline: true,
                buttons: buttons
            };
            log('debug', `Created keyboard with ${buttons.length} buttons`);
            return keyboard;
        }
        
        return null;
        
    } catch (error) {
        log('error', 'Error creating keyboard:', error);
        return null;
    }
}

