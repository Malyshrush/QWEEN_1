      const row = comments[i];
      const trigger = (row['Триггер'] || '').trim();
      const answer = (row['Ответ'] || '').trim();
      const fallbackAnswer = (row['Заготовленный ответ'] || '').trim();
      
      if (!trigger && fallbackAnswer) {
        fallbackRow = row;
        continue;
      }
      
      if (trigger) {
        const matchType = (row['Точно/Не точно'] || '').trim().toUpperCase();
        const caseSensitive = (row['Регистр'] || '').trim().toLowerCase() === 'важно';
        const triggerMatch = await checkTriggerMatch(text, trigger, matchType, caseSensitive, userId, groupId);
        
        if (triggerMatch) {
          log('debug', `✅ Comment trigger matched: "${trigger}"`);
          
          const conditionsMet = await checkAllConditions(row, {
            userId: userId,
            groupId: groupId,
            text: text,
            postId: postIdentifier,
            commentText: text,
            eventType: 'comment'
          });
          
          if (conditionsMet) {
            log('debug', `✅ All conditions met for comment trigger: "${trigger}"`);
            matchedRowWithConditions = row;
            break;
          } else {
            log('debug', `❌ Conditions not met for comment trigger: "${trigger}"`);
            if (fallbackAnswer && !matchedRowWithoutConditions) {
              matchedRowWithoutConditions = row;
            }
          }
        }
      }
    }
    
    if (matchedRowWithConditions) {
      await sendCommentAndPerformActions(comment, groupId, matchedRowWithConditions, true);
    } else if (matchedRowWithoutConditions) {
      await sendFallbackCommentFromRow(comment, groupId, matchedRowWithoutConditions);
    } else if (fallbackRow) {
      await sendFallbackCommentFromRow(comment, groupId, fallbackRow);
    }
  } catch (error) {
    log('error', 'Comment handling error:', error);
  }
}

async function sendCommentAndPerformActions(comment, groupId, row, isComment = true) {
  try {
    const answer = (row['Ответ'] || '').trim();
    const processedAnswer = await replaceVariables(answer, comment.from_id, `-${groupId}`);
    const replyText = `@id${comment.from_id} ${processedAnswer}`;
    
    log('debug', `💬 Sending comment reply to ${comment.from_id}`);
    
    const success = await sendCommentVK(-groupId, comment.post_id, replyText, comment.id);
    
    if (success) {
      await performRowActions(row, comment.from_id, `-${groupId}`, true);
    }
  } catch (error) {
    log('error', '❌ Error sending comment:', error);
  }
}

async function sendFallbackCommentFromRow(comment, groupId, row) {
  try {
    const fallbackAnswer = (row['Заготовленный ответ'] || '').trim();
    if (!fallbackAnswer) return;
    
    const processedAnswer = await replaceVariables(fallbackAnswer, comment.from_id, `-${groupId}`);
    const replyText = `@id${comment.from_id} ${processedAnswer}`;
    
    log('debug', `💬 Sending fallback comment to ${comment.from_id}`);
    
    await sendCommentVK(-groupId, comment.post_id, replyText, comment.id);
    log('debug', `✅ Fallback comment sent successfully`);
  } catch (error) {
    log('error', '❌ Error sending fallback comment:', error);
  }
}


