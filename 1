async function sendMessageVK(userId, text, keyboard = null, groupId = '-229445618') {
  try {
    log('debug', `📤 Sending message to ${userId}`);
    
    const params = new URLSearchParams({
      user_id: userId,
      message: text,
      random_id: Math.floor(Math.random() * 1e7),
      v: '5.199',
      access_token: VK_TOKEN
    });
    
    // 🔥 ИСПРАВЛЕНИЕ: НЕ используем reply_to для сообщений сообщества
    // Это вызывает ошибку "reply_to have to be message from same chat"
    
    if (keyboard) {
      params.append('keyboard', JSON.stringify(keyboard));
    }
    
    log('debug', `🚀 Sending to VK API...`);
    
    const response = await axios.post(
      'https://api.vk.com/method/messages.send',
      params,
      {
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded'
        },
        timeout: 10000
      }
