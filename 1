function checkCommunityMention(text, groupId) {
  const patterns = [`[club${groupId}|`, `[public${groupId}|`, `[id-${groupId}|`];
  const lowerText = (text || '').toLowerCase();
  return patterns.some(p => lowerText.includes(p.toLowerCase()));
}

