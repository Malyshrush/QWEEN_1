async function handleMessage(data) {
  try {
    const message = data.object.message;
    const text = (message.text || '').trim();
    const userId = message.from_id;
    const groupId = data.group_id;
    
    log('info', `📨 ========== NEW MESSAGE ==========`);
    log('info', `📨 From: ${userId}, Text: "${text}"`);
    
    // Проверка дублирования
    const messageKey = `msg_${userId}_${message.conversation_message_id || message.id}`;
    if (processedMessages.has(messageKey)) {
      log('debug', `⚠️ Message already processed: ${messageKey}`);
      return;
    }
    processedMessages.set(messageKey, Date.now());
    
    if (!VK_TOKEN) {
      log('error', '❌ VK_TOKEN is not set!');
      return;
    }
    
    // ШАГ 1: Обновляем данные пользователя
    log('debug', `👤 STEP 1: Starting updateUserData for ${userId}`);
    const userUpdated = await updateUserData(userId);
    if (!userUpdated) {
      log('debug', `⚠️ User ${userId} not in database, but continuing processing...`);
    } else {
      log('debug', `✅ User data updated successfully`);
    }
    
    // ШАГ 2: Загружаем сообщения
    log('debug', `📋 STEP 2: Loading MESSAGES COMMUNITY data`);
    const messages = await getSheetData('MESSAGES COMMUNITY');
    if (!messages) {
      log('error', `❌ STEP 2 FAILED: No messages data loaded`);
      return;
    }
    log('debug', `✅ STEP 2 COMPLETED: Loaded ${messages.length} message rules`);
    
    // ДИАГНОСТИКА: Выводим все триггеры
    log('debug', `🔍 ALL TRIGGERS:`);
    messages.forEach((row, index) => {
      const trigger = (row['Триггер'] || '').trim();
      if (trigger) {
        log('debug', `   [${index}] "${trigger}" → "${(row['Ответ'] || '').substring(0, 50)}..."`);
      }
    });
    
    let matchedRowWithConditions = null;
    let matchedRowWithoutConditions = null;
    let fallbackRow = null;
    
    log('debug', `🔍 STEP 3: Starting search through ${messages.length} rows...`);
    
    // ПРОХОДИМ ПО КАЖДОЙ СТРОКЕ
    for (let i = 0; i < messages.length; i++) {
      const row = messages[i];
      const trigger = (row['Триггер'] || '').trim();
      const answer = (row['Ответ'] || '').trim();
      const fallbackAnswer = (row['Заготовленный ответ'] || '').trim();
      
      log('debug', `\n🔍 [Row ${i}] Checking: trigger="${trigger}"`);
      
      // Запоминаем строку с заготовленным ответом (без триггера)
      if (!trigger && fallbackAnswer) {
        log('debug', `⭐ [Row ${i}] Found GENERAL FALLBACK row`);
        fallbackRow = row;
        continue;
      }
      
      // Пропускаем строки без триггера
      if (!trigger) {
        log('debug', `➡️ [Row ${i}] Skipping - no trigger`);
        continue;
      }
      
      // Проверяем совпадение триггера
      log('debug', `🔍 [Row ${i}] Checking trigger: "${trigger}" vs user text: "${text}"`);
      const matchType = (row['Точно/Не точно'] || '').trim().toUpperCase();
      const caseSensitive = (row['Регистр'] || '').trim().toLowerCase() === 'важно';
      const triggerMatch = await checkTriggerMatch(text, trigger, matchType, caseSensitive, userId, groupId);
      
      if (triggerMatch) {
        log('debug', `✅ [Row ${i}] Trigger "${trigger}" MATCHED!`);
        
        // Проверяем условия
        log('debug', `🔍 [Row ${i}] Checking conditions...`);
        const conditionsMet = await checkAllConditions(row, {
          userId: userId,
          groupId: groupId,
          text: text,
          eventType: 'message'
        });
        
        if (conditionsMet) {
          log('debug', `🎯 [Row ${i}] ALL CONDITIONS MET!`);
          log('debug', `🎯 [Row ${i}] Answer found: "${answer}"`);
          matchedRowWithConditions = row;
          break;
        } else {
          log('debug', `❌ [Row ${i}] Conditions not met`);
          if (fallbackAnswer && !matchedRowWithoutConditions) {
            log('debug', `💾 [Row ${i}] Storing as fallback candidate`);
            matchedRowWithoutConditions = row;
          }
        }
      } else {
        log('debug', `❌ [Row ${i}] Trigger "${trigger}" NOT matched`);
      }
    }
    
    // ШАГ 4: Принятие решения об ответе
    log('debug', `\n📤 STEP 4: DECISION MAKING`);
    log('debug', `   - Matched with conditions: ${matchedRowWithConditions ? 'YES' : 'NO'}`);
    log('debug', `   - Matched without conditions: ${matchedRowWithoutConditions ? 'YES' : 'NO'}`);
    log('debug', `   - General fallback: ${fallbackRow ? 'YES' : 'NO'}`);
    
    if (matchedRowWithConditions) {
      log('debug', `🚀 STEP 4.1: SENDING MAIN RESPONSE`);
      await sendMessageAndPerformActions(userId, matchedRowWithConditions, message, false);
    } else if (matchedRowWithoutConditions) {
      log('debug', `🚀 STEP 4.2: SENDING FALLBACK FROM TRIGGER ROW`);
      await sendFallbackResponseFromRow(userId, matchedRowWithoutConditions, message);
    } else if (fallbackRow) {
      log('debug', `🚀 STEP 4.3: SENDING GENERAL FALLBACK`);
      await sendFallbackResponseFromRow(userId, fallbackRow, message);
    } else {
      log('debug', `🚀 STEP 4.4: SENDING DEFAULT RESPONSE`);
      await sendDefaultResponse(userId, message);
    }
    
    log('info', `✅ ========== MESSAGE PROCESSING COMPLETE ==========`);
  } catch (error) {
    log('error', '❌ CRITICAL ERROR in handleMessage:', error);
    log('error', error.stack);
  }
}

