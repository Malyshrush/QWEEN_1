// ====================== ЛОГГЕР ======================
function log(level, ...args) {
  const levels = ['debug', 'info', 'warn', 'error', 'none'];
  const currentLevelIndex = levels.indexOf(LOG_LEVEL);
  const messageLevelIndex = levels.indexOf(level);
  if (messageLevelIndex < currentLevelIndex) return;
  
  const timestamp = new Date().toISOString();
  if (level === 'error') {
    console.error(`[${timestamp}] [${level.toUpperCase()}]`, ...args);
  } else if (level === 'warn') {
    console.warn(`[${timestamp}] [${level.toUpperCase()}]`, ...args);
  } else if (level === 'info') {
    console.info(`[${timestamp}] [${level.toUpperCase()}]`, ...args);
  } else if (level === 'debug') {
    console.debug(`[${timestamp}] [${level.toUpperCase()}]`, ...args);
  } else {
    console.log(`[${timestamp}] [${level.toUpperCase()}]`, ...args);
  }
}

// ====================== ИНИЦИАЛИЗАЦИЯ S3 ======================
async function initializeStorage() {
  log('info', '🔧 Checking Object Storage initialization...');
  for (const [sheetName, fileName] of Object.entries(FILE_MAP)) {
    try {
      await s3Client.send(new GetObjectCommand({ Bucket: BUCKET_NAME, Key: fileName }));
      log('debug', `✅ File exists: ${fileName}`);
    } catch (error) {
      if (error.name === 'NoSuchKey' || error.$metadata?.httpStatusCode === 404) {
        log('info', `📄 Creating ${fileName}...`);
        try {
          await s3Client.send(new PutObjectCommand({
            Bucket: BUCKET_NAME,
            Key: fileName,
            Body: JSON.stringify(DEFAULT_DATA[sheetName] || [], null, 2),
            ContentType: 'application/json'
          }));
          log('info', `✅ Created ${fileName}`);
        } catch (createError) {
          log('error', `❌ Failed to create ${fileName}:`, createError.message);
        }
      }
    }
  }
}

// ====================== РАБОТА С ДАННЫМИ ======================
async function getSheetData(sheetName) {
  const fileName = FILE_MAP[sheetName];
  if (!fileName) {
    log('error', `Unknown sheet: ${sheetName}`);
    return [];
  }
  
  const now = Date.now();
  const ttl = memoryCache.ttl[sheetName] || 300000;
  
  if (memoryCache.data[sheetName] && (now - memoryCache.lastUpdated[sheetName]) < ttl) {
    return memoryCache.data[sheetName];
  }
  
  try {
    const response = await s3Client.send(new GetObjectCommand({ Bucket: BUCKET_NAME, Key: fileName }));
    const data = await response.Body.transformToString();
    const json = JSON.parse(data);
    
    memoryCache.data[sheetName] = json;
    memoryCache.lastUpdated[sheetName] = now;
    log('debug', `Loaded ${sheetName}: ${json?.length || 0} rows`);
    return json;
  } catch (error) {
    log('error', `Error loading ${sheetName}:`, error.message);
    return memoryCache.data[sheetName] || [];
  }
}

async function saveSheetData(sheetName, data) {
  const fileName = FILE_MAP[sheetName];
  if (!fileName) throw new Error(`Unknown sheet: ${sheetName}`);
  
  try {
    log('info', `💾 Saving ${sheetName}...`);
    await s3Client.send(new PutObjectCommand({
      Bucket: BUCKET_NAME,
      Key: fileName,
      Body: JSON.stringify(data, null, 2),
      ContentType: 'application/json'
    }));
    
    memoryCache.data[sheetName] = data;
    memoryCache.lastUpdated[sheetName] = Date.now();
    log('info', `✅ Saved ${sheetName} successfully`);
    return true;
  } catch (error) {
    log('error', `❌ Error saving ${sheetName}:`, error.message);
    throw error;
  }
}

function invalidateCache(sheetName) {
  delete memoryCache.data[sheetName];
  delete memoryCache.lastUpdated[sheetName];
  log('debug', `[Cache] Invalidated: ${sheetName}`);
}

