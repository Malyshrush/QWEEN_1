async function processDelayed() {
    try {
        const delayed = await getSheetData('Отложенные');
        const messages = await getSheetData('MESSAGES COMMUNITY');
        const comments = await getSheetData('COMMENTS');
        const now = new Date();
        let hasChanges = false;

        for (const item of delayed) {
            if (item['Статус'] !== 'Ожидает') continue;

            const scheduledTime = new Date(item['Дата и время отправки']);
            if (scheduledTime > now) continue;

            const userId = item['ID Пользователя'];
            const groupId = item['Группа'];
            const stepName = item['Шаг'];
            const type = item['Тип'] || 'message';

            const rows = type === 'comment' ? comments : messages;
            const row = rows.find(r => (r['Шаг'] || '').trim() === stepName);

          if (row) {
              const answer = row['Ответ'] || '';
              const processedAnswer = await replaceVariables(answer, userId, groupId);
              
              try {
                  const keyboard = createKeyboard(row, 'Кнопка Ответа', 'Цвет/Ссылка Ответа');
                  await sendMessageVK(userId, processedAnswer, keyboard, groupId);
                  
                  // 🔥 НОВОЕ: Выполняем действия из строки шага
                  log('debug', `🛠️ Executing actions from step ${stepName}`);
                  await performRowActions(row, userId, groupId, type === 'comment');
                  
                  item['Статус'] = 'Отправлено';
                  item['Фактическое время отправки'] = now.toISOString().replace('T', ' ').substring(0, 19);
                  log('debug', `✅ Sent delayed step ${stepName} to ${userId} with actions`);
                  hasChanges = true;
              } catch (sendError) {
                  item['Статус'] = 'Ошибка';
                  item['Ошибка'] = sendError.message;
                  log('error', `❌ Error sending delayed step ${stepName}:`, sendError.message);
                  hasChanges = true;
              }
          }
        }

        if (hasChanges) {
            await saveSheetData('Отложенные', delayed);
            invalidateCache('Отложенные');
            log('debug', `💾 Saved delayed changes`);
        }
    } catch (error) {
        log('error', '❌ Error in processDelayed:', error);
    }
}


function parseDelay(delayStr) {
if (!delayStr) return 0;
const str = delayStr.trim().toLowerCase();
const value = parseInt(str) || 0;
// Часы
if (str.includes('ч.') || str.includes('часов') || str.includes('часа') || str.includes('час')) {
return value * 3600;
}
// Минуты
if (str.includes('мин.') || str.includes('минут') || str.includes('минуту') || str.includes('мин')) {
return value * 60;
}
// Секунды (по умолчанию)
return value;
}

