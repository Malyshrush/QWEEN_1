async function loadData(tab) {
const sheet = sheetMap[tab];
document.getElementById('loading-'+tab).style.display = 'block';
debug('Loading ' + sheet);
try {
// 🔥 ИСПРАВЛЕНИЕ: Корректное формирование URL для Яндекс Функций
const baseUrl = window.location.origin + window.location.pathname;
const url = baseUrl + '?sheet=' + encodeURIComponent(sheet);
//log('debug', '🔗 Fetching data from:' ${url});
const res = await fetch(url);
if (!res.ok) throw new Error('HTTP ' + res.status);
const data = await res.json();
dataStore[tab] = data || [];
renderTable(tab, data);
debug('Loaded ' + (data?.length || 0) + ' rows');
} catch (e) {
debug('Error: ' + e.message);
showStatus('Ошибка загрузки: ' + e.message, 'error');
}
document.getElementById('loading-'+tab).style.display = 'none';
}
