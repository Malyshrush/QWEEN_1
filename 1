async function scheduleStepMessage(userId, groupId, stepData, isComment = false) {
    try {
        const [step, delayStr] = stepData.split(',').map(s => s.trim());
        const delay = parseDelay(delayStr);
        log('debug', `⏰ Scheduling step: "${stepData}" → step="${step}", delay=${delay}sec`);
        if (delay > 0 && step) {
            log('debug', `⏰ Scheduling step ${step} for user ${userId} in ${delay} seconds`);
            const scheduledTime = new Date(Date.now() + delay * 1000);
            const delayed = await getSheetData('Отложенные');
            delayed.push({
                '№': (delayed.length + 1).toString(),
                'Шаг': step,
                'ID Пользователя': userId.toString(),
                'Группа': groupId.toString(),
                'Тип': isComment ? 'comment' : 'message',
                'Дата и время отправки': scheduledTime.toISOString().replace('T', ' ').substring(0, 19),
                'Статус': 'Ожидает',
                'Фактическое время отправки': '',
                'Ошибка': ''
            });
            await saveSheetData('Отложенные', delayed);
            invalidateCache('Отложенные');
            log('debug', `✅ Step ${step} saved to delayed for ${userId}`);
        } else {
            log('warn', `⚠️ Step NOT scheduled: delay=${delay}, step="${step}"`);
        }
    } catch (error) {
        log('error', '❌ Error scheduling step message:', error);
    }
}


