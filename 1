async function updateUserGroups(userId, addGroupsStr = '', removeGroupsStr = '') {
  try {
    log('debug', `👥 Updating groups for user ${userId}: add="${addGroupsStr}", remove="${removeGroupsStr}"`);
    
    const users = await getSheetData('USERS');
    const userRow = users.find(r => r['ID'] == userId);
    
    if (!userRow) {
      log('error', `❌ User ${userId} not found in USERS sheet`);
      return;
    }
    
    const currentGroups = (userRow['ГРУППА'] || '').split(',').map(g => g.trim()).filter(g => g);
    log('debug', `👥 Current groups: [${currentGroups}]`);
    
    const removeGroups = removeGroupsStr.split(',').map(g => g.trim()).filter(g => g);
    let newGroups = currentGroups.filter(group => !removeGroups.includes(group));
    log('debug', `👥 After removal: [${newGroups}]`);
    
    const addGroups = addGroupsStr.split(',').map(g => g.trim()).filter(g => g);
    addGroups.forEach(group => {
      if (!newGroups.includes(group)) {
        newGroups.push(group);
      }
    });
    log('debug', `👥 After addition: [${newGroups}]`);
    
    // 🔥 НОВОЕ: Каждая группа с новой строки
userRow['ГРУППА'] = newGroups.join('\n');
    
    await saveSheetData('USERS', users);
    invalidateCache('USERS');
    log('debug', `✅ Groups updated for user ${userId}: ${newGroups.join(',')}`);
  } catch (error) {
    log('error', '❌ Error updating user groups:', error);
  }
}

