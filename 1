// ====================== ПРОВЕРКА ТРИГГЕРОВ ======================
async function checkTriggerMatch(text, trigger, matchType, caseSensitive, userId, groupId) {
  try {
    if (!trigger || !trigger.trim()) {
      log('debug', `❌ No trigger specified`);
      return false;
    }
    
    let cleanTrigger = trigger.trim();
    
    if (cleanTrigger.includes('{$') || cleanTrigger.includes('[$') || cleanTrigger.includes('%')) {
      log('debug', `🔍 Trigger contains variables, replacing...`);
      const processedTrigger = await replaceVariables(cleanTrigger, userId, groupId);
      cleanTrigger = processedTrigger.trim();
    }
    
    log('debug', `🔍 Trigger: original="${trigger}", processed="${cleanTrigger}"`);
    
    if (!cleanTrigger) {
      log('debug', `❌ Empty trigger after processing`);
      return false;
    }
    
    const triggerPatterns = cleanTrigger.split(',').map(t => t.trim()).filter(t => t);
    log('debug', `🔍 Trigger patterns: [${triggerPatterns.map(p => `"${p}"`).join(', ')}]`);
    
    const actualMatchType = (matchType || '').trim().toUpperCase() || 'НЕ ТОЧНО';
    const isCaseSensitive = (caseSensitive || '').trim().toLowerCase() === 'важно';
    log('debug', `🔍 Match type: ${actualMatchType}, Case sensitive: ${isCaseSensitive}`);
    
    for (const pattern of triggerPatterns) {
      log('debug', `🔍 Checking pattern: "${pattern}" vs user text: "${text}"`);
      let matchFound = false;
      
      if (actualMatchType === 'ТОЧНО') {
        if (isCaseSensitive) {
          matchFound = text === pattern;
          log('debug', `🔍 Exact case-sensitive: "${text}" === "${pattern}" → ${matchFound}`);
        } else {
          matchFound = text.toLowerCase() === pattern.toLowerCase();
          log('debug', `🔍 Exact case-insensitive: "${text.toLowerCase()}" === "${pattern.toLowerCase()}" → ${matchFound}`);
        }
      } else {
        if (isCaseSensitive) {
          matchFound = text.includes(pattern);
          log('debug', `🔍 Partial case-sensitive: "${text}" includes "${pattern}" → ${matchFound}`);
        } else {
          const textLower = text.toLowerCase();
          const patternLower = pattern.toLowerCase();
          matchFound = textLower.includes(patternLower);
          log('debug', `🔍 Partial case-insensitive: "${textLower}" includes "${patternLower}" → ${matchFound}`);
        }
      }
      
      if (matchFound) {
        log('debug', `✅ Pattern "${pattern}" MATCHED!`);
        return true;
      } else {
        log('debug', `❌ Pattern "${pattern}" not matched`);
      }
    }
    
    log('debug', `❌ No trigger patterns matched`);
    return false;
  } catch (error) {
    log('error', `❌ Error in checkTriggerMatch:`, error);
    return false;
  }
}

// ====================== ПРОВЕРКА ГРУПП ======================
async function checkUserGroups(userId, required) {
  try {
    if (!required || !required.trim()) return true;
    
    log('debug', `🔍 Checking groups for user ${userId}, required: "${required}"`);
    
    invalidateCache('USERS');
    const users = await getSheetData('USERS');
    const user = users.find(u => u['ID'] == userId);
    
    if (!user) {
      log('debug', `❌ User ${userId} not found`);
      return false;
    }
    
    // 🔥 Поддержка обоих форматов: запятые И новые строки
const userGroups = (user['ГРУППА'] || '')
    .split(/[\n,]+/)  // 🔥 Разделяем по \n ИЛИ ,
    .map(g => g.trim().toLowerCase())
    .filter(g => g);
    const requiredGroupsArray = required.split(',').map(g => g.trim().toLowerCase());
    
    log('debug', `🔍 User groups: [${userGroups}], Required: [${requiredGroupsArray}]`);
    
    const hasRequiredGroup = requiredGroupsArray.some(req => userGroups.includes(req));
    
    log('debug', `🔍 Group check result: ${hasRequiredGroup}`);
    return hasRequiredGroup;
  } catch (error) {
    log('error', '❌ Error checking user groups:', error);
    return false;
  }
}

// ====================== ПРОВЕРКА ШАГОВ ======================
function checkStepCondition(requiredSteps, userSteps) {
  if (!requiredSteps || !requiredSteps.trim()) return true;
  if (!userSteps || !userSteps.trim()) return false;
  
  const requiredStepsArray = requiredSteps.split(',').map(s => s.trim());
  const userStepsArray = userSteps.split(',').map(s => s.trim());
  
  log('debug', `🔍 Step check: required=[${requiredStepsArray}], user=[${userStepsArray}]`);
  
  return requiredStepsArray.some(step => userStepsArray.includes(step));
}

async function getUserCurrentSteps(userId, bot = null) {
    try {
        const users = await getSheetData('USERS');
        const user = users.find(u => u['ID'] == userId);
        if (!user) return '';
        
const allBots = (user['Текущий Бот'] || '')
    .split(/[\n,]+/)  // 🔥 Разделяем по \n ИЛИ ,
    .map(b => b.trim())
    .filter(b => b);

const allSteps = (user['Текущий Шаг'] || '')
    .split(/[\n,]+/)  // 🔥 Разделяем по \n ИЛИ ,
    .map(s => s.trim())
    .filter(s => s);
        
        // 🔥 Если указан бот - возвращаем шаги только этого бота
        if (bot) {
            const botIndex = allBots.findIndex(b => b === bot);
            if (botIndex !== -1 && allSteps[botIndex]) {
                return allSteps[botIndex];
            }
            return '';
        }
        
        // 🔥 Если бот не указан - возвращаем все шаги (для обратной совместимости)
        const steps = user ? (user['Текущий Шаг'] || '') : '';
        log('debug', `🔍 User ${userId} current steps: "${steps}"`);
        return steps;
    } catch (error) {
        log('error', 'Error getting user steps:', error);
        return '';
    }
}


// ====================== ВСЕ УСЛОВИЯ ======================
async function checkAllConditions(row, options) {
    try {
        const { userId, groupId, text, eventType = 'message', postId, commentText } = options;
        log('debug', `🔍 Checking ALL conditions for user ${userId}`);
        
        // 🔥 ПЕРЕМЕННЫЕ ОБЪЯВЛЕНЫ СРАЗУ В НАЧАЛЕ
        const userVarCondition = (row['Пользовательская Переменная ПП'] || '').trim();
        const globalVarCondition = (row['Глобальная Переменная ГП'] || '').trim();
        
        // 1. Проверка групп
        const requiredGroups = (row['Ответить если в Группе'] || '').trim();
        if (requiredGroups) {
            log('debug', `🔍 Checking groups: "${requiredGroups}"`);
            const userInGroups = await checkUserGroups(userId, requiredGroups);
            if (!userInGroups) {
                log('debug', `❌ User not in required groups`);
                return false;
            }
            log('debug', `✅ User is in required groups`);
        }
        
        // 2. Проверка шага (только для сообщений)
        if (eventType === 'message') {
            const requiredStep = (row['Ответил на Шаг'] || '').trim();
            if (requiredStep) {
                log('debug', `🔍 Checking step: "${requiredStep}"`);
                const userSteps = await getUserCurrentSteps(userId);
                log('debug', `🔍 User current steps: "${userSteps}"`);
                const stepCondition = checkStepCondition(requiredStep, userSteps);
                if (!stepCondition) {
                    log('debug', `❌ Step condition not met`);
                    return false;
                }
                log('debug', `✅ Step condition met`);
            }
        }
        
        // 3. 🔥 ПРОВЕРКА ПЕРЕМЕННЫХ (теперь переменные уже объявлены)
        if (userVarCondition || globalVarCondition) {
            log('debug', `🔍 Checking variable conditions`);
            const varConditionsMet = await checkVariableConditions(userVarCondition, globalVarCondition, userId, groupId);
            if (!varConditionsMet) {
                log('debug', `❌ Variable conditions not met`);
                return false;
            }
            log('debug', `✅ Variable conditions met`);
        }
        
        // 4. Для комментариев - проверка поста и отметки
        if (eventType === 'comment') {
            const postCondition = (row['Пост'] || '').trim();
            if (postCondition && postCondition !== 'ВСЕ') {
                const allowedPosts = postCondition.split(',').map(p => p.trim());
                const postMatch = allowedPosts.includes(postId);
                if (!postMatch) {
                    log('debug', `❌ Post condition not met`);
                    return false;
                }
            }
            const mentionCondition = (row['Отметили'] || '').trim().toUpperCase();
            if (mentionCondition) {
                const mentioned = checkCommunityMention(commentText, groupId);
                if (mentionCondition === 'ДА' && !mentioned) {
                    log('debug', `❌ Mention condition not met (required mention)`);
                    return false;
                }
                if (mentionCondition === 'НЕТ' && mentioned) {
                    log('debug', `❌ Mention condition not met (should not mention)`);
                    return false;
                }
            }
        }
        
        log('debug', `✅ All conditions passed`);
        return true;
    } catch (error) {
        log('error', '❌ Error in checkAllConditions:', error);
        return false;
    }
}




// ====================== ПРОВЕРКА УСЛОВИЙ ПЕРЕМЕННЫХ ======================
async function checkVariableConditions(userVarCondition, globalVarCondition, userId, groupId) {
    try {
        log('debug', `🔍 Checking variable conditions for user ${userId}`);
        
        // Проверка пользовательских переменных
        if (userVarCondition && userVarCondition.trim()) {
            const userVars = await getUserVariables(userId);
            const conditions = userVarCondition.split(/[;,]/).map(c => c.trim()).filter(c => c);
            
            for (const condition of conditions) {
                log('debug', `🔍 Checking user var condition: "${condition}"`);
                
                // Разбираем условие
                let varName, operator, expectedValue;
                
                if (condition.includes('!=')) {
                    [varName, expectedValue] = condition.split('!=').map(s => s.trim());
                    operator = '!=';
                } else if (condition.includes('>=')) {
                    [varName, expectedValue] = condition.split('>=').map(s => s.trim());
                    operator = '>=';
                } else if (condition.includes('<=')) {
                    [varName, expectedValue] = condition.split('<=').map(s => s.trim());
                    operator = '<=';
                } else if (condition.includes('=')) {
                    [varName, expectedValue] = condition.split('=').map(s => s.trim());
                    operator = '=';
                } else if (condition.includes('>')) {
                    [varName, expectedValue] = condition.split('>').map(s => s.trim());
                    operator = '>';
                } else if (condition.includes('<')) {
                    [varName, expectedValue] = condition.split('<').map(s => s.trim());
                    operator = '<';
                } else {
                    // Просто проверка существования
                    varName = condition.trim();
                    operator = 'exists';
                }
                
                const varValue = userVars[varName.toLowerCase()];
                
                // Проверяем условие
                let conditionMet = false;
                
                if (operator === 'exists') {
                    conditionMet = varValue !== undefined;
                    log('debug', `🔍 User var ${varName} exists: ${conditionMet}`);
                } else if (operator === '=') {
                    conditionMet = varValue === expectedValue;
                    log('debug', `🔍 User var ${varName} = "${expectedValue}": ${conditionMet} (actual: "${varValue}")`);
                } else if (operator === '!=') {
                    conditionMet = varValue !== expectedValue;
                    log('debug', `🔍 User var ${varName} != "${expectedValue}": ${conditionMet}`);
                } else if (operator === '>') {
                    conditionMet = parseFloat(varValue) > parseFloat(expectedValue);
                    log('debug', `🔍 User var ${varName} > ${expectedValue}: ${conditionMet}`);
                } else if (operator === '>=') {
                    conditionMet = parseFloat(varValue) >= parseFloat(expectedValue);
                    log('debug', `🔍 User var ${varName} >= ${expectedValue}: ${conditionMet}`);
                } else if (operator === '<') {
                    conditionMet = parseFloat(varValue) < parseFloat(expectedValue);
                    log('debug', `🔍 User var ${varName} < ${expectedValue}: ${conditionMet}`);
                } else if (operator === '<=') {
                    conditionMet = parseFloat(varValue) <= parseFloat(expectedValue);
                    log('debug', `🔍 User var ${varName} <= ${expectedValue}: ${conditionMet}`);
                }
                
                if (!conditionMet) {
                    log('debug', `❌ User variable condition failed: ${condition}`);
                    return false;
                }
            }
        }
        
        // Проверка глобальных переменных
        if (globalVarCondition && globalVarCondition.trim()) {
            const { globalVars } = await getGlobalVariables();
            const conditions = globalVarCondition.split(/[;,]/).map(c => c.trim()).filter(c => c);
            
            for (const condition of conditions) {
                log('debug', `🔍 Checking global var condition: "${condition}"`);
                
                let varName, operator, expectedValue;
                
                if (condition.includes('!=')) {
                    [varName, expectedValue] = condition.split('!=').map(s => s.trim());
                    operator = '!=';
                } else if (condition.includes('==') || condition.includes('=')) {
                    [varName, expectedValue] = condition.split(/==|=/).map(s => s.trim());
                    operator = '=';
                } else if (condition.includes('>')) {
                    [varName, expectedValue] = condition.split('>').map(s => s.trim());
                    operator = '>';
                } else if (condition.includes('<')) {
                    [varName, expectedValue] = condition.split('<').map(s => s.trim());
                    operator = '<';
                } else {
                    varName = condition.trim();
                    operator = 'exists';
                }
                
                const varValue = globalVars[varName.toLowerCase()];
                
                let conditionMet = false;
                
                if (operator === 'exists') {
                    conditionMet = varValue !== undefined;
                    log('debug', `🔍 Global var ${varName} exists: ${conditionMet}`);
                } else if (operator === '=') {
                    conditionMet = varValue === expectedValue;
                    log('debug', `🔍 Global var ${varName} = "${expectedValue}": ${conditionMet} (actual: "${varValue}")`);
                } else if (operator === '!=') {
                    conditionMet = varValue !== expectedValue;
                    log('debug', `🔍 Global var ${varName} != "${expectedValue}": ${conditionMet}`);
                } else if (operator === '>') {
                    conditionMet = parseFloat(varValue) > parseFloat(expectedValue);
                    log('debug', `🔍 Global var ${varName} > ${expectedValue}: ${conditionMet}`);
                } else if (operator === '>=') {
                    conditionMet = parseFloat(varValue) >= parseFloat(expectedValue);
                    log('debug', `🔍 Global var ${varName} >= ${expectedValue}: ${conditionMet}`);
                } else if (operator === '<') {
                    conditionMet = parseFloat(varValue) < parseFloat(expectedValue);
                    log('debug', `🔍 Global var ${varName} < ${expectedValue}: ${conditionMet}`);
                } else if (operator === '<=') {
                    conditionMet = parseFloat(varValue) <= parseFloat(expectedValue);
                    log('debug', `🔍 Global var ${varName} <= ${expectedValue}: ${conditionMet}`);
                }
                
                if (!conditionMet) {
                    log('debug', `❌ Global variable condition failed: ${condition}`);
                    return false;
                }
            }
        }
        
        log('debug', `✅ All variable conditions passed`);
        return true;
    } catch (error) {
        log('error', '❌ Error in checkVariableConditions:', error);
        return false;
    }
}
        

