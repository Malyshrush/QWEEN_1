log('debug', `🔧 Getting user variables for ${userId}`);
const users = await getSheetData('USERS');
if (!users) {
log('debug', `🔧 No users data found`);
return {};
}
const user = users.find(u => u['ID'] == userId);
if (!user) {
log('debug', `🔧 User ${userId} not found`);
return {};
}

// 🔥 Поддержка обоих форматов: запятые И новые строки
// 🔥 Исправлено: корректное регулярное выражение + одно объявление
const varNamesRaw = (user['Пользовательская'] || '');
const varValuesRaw = (user['Значения ПП'] || '');

log('debug', `🔍 Raw user vars: names="${varNamesRaw}", values="${varValuesRaw}"`);

const varNames = varNamesRaw
.split(/[\r\n,]+/)  // ✅ Корректный регексп: \r\n для Windows, \n для Unix, , для разделения
.map(v => v.trim().toLowerCase())
.filter(v => v);

const varValues = varValuesRaw
.split(/[\r\n,]+/)
.map(v => v.trim())
.filter(v => v);

log('debug', `🔍 Parsed user vars:`, { names: varNames, values: varValues });

const variables = {};
for (let i = 0; i < Math.min(varNames.length, varValues.length); i++) {
